# ─────────────────────────────────────────────
# CORE
# ─────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.0-flash

# ─────────────────────────────────────────────
# TWILIO (WhatsApp Sandbox)
# ─────────────────────────────────────────────
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_WHATSAPP_FROM=whatsapp:+14155238886

# ─────────────────────────────────────────────
# VAPI (Voice Agent)
# ─────────────────────────────────────────────
VAPI_API_KEY=your_vapi_api_key
VAPI_ASSISTANT_ID=your_vapi_assistant_id

# ─────────────────────────────────────────────
# ELEVENLABS (TTS via Vapi)
# ─────────────────────────────────────────────
ELEVENLABS_API_KEY=your_elevenlabs_api_key
ELEVENLABS_VOICE_ID=your_voice_id

# ─────────────────────────────────────────────
# UPSTASH REDIS (Session Cache)
# ─────────────────────────────────────────────
UPSTASH_REDIS_REST_URL=https://your-db.upstash.io
UPSTASH_REDIS_REST_TOKEN=your_upstash_token
SESSION_TTL_HOURS=24

# ─────────────────────────────────────────────
# SUPABASE (Persistent Storage)
# ─────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_service_role_key

# ─────────────────────────────────────────────
# ADMIN PANEL (/krsna)
# ─────────────────────────────────────────────
ADMIN_PASSWORD=change_me_strong_password
ADMIN_API_KEY=change_me_strong_api_key

# ─────────────────────────────────────────────
# APP
# ─────────────────────────────────────────────
ENVIRONMENT=development
LOG_LEVEL=INFO
PORT=8000
# Public-facing base URL for this service (used by Vapi to self-reference webhook URL)
# e.g. https://aadhya.onrender.com   — no trailing slash
BASE_URL=http://localhost:8000
# Allowed CORS origins — comma-separated. Use * for local dev only.
# e.g. https://admin.tatvaops.com,https://tatvaops.com
CORS_ORIGINS=*
